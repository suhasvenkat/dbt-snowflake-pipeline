dbt_snowflake_pipeline:
  target: dev
  outputs:
    dev:
      type: snowflake
      account: <your_account>
      user: <your_username>
      password: <your_password>
      role: TRANSFORMER
      database: ANALYTICS_DEV
      warehouse: COMPUTE_WH
      schema: DBT_DEV
      threads: 4
    prod:
      type: snowflake
      account: <your_account>
      user: <your_username>
      password: <your_password>
      role: TRANSFORMER
      database: ANALYTICS_PROD
      warehouse: COMPUTE_WH
      schema: DBT_PROD
      threads: 8
